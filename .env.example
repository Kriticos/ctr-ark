# -----------------------------------------------------------------------------
# Aplicação
# -----------------------------------------------------------------------------
APP_NAME=LaraSaaS
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# URL pública (a que você acessa no navegador).
APP_URL=http://localhost

# Porta publicada no host (mapeia para a porta 80 do container `laravel.test`).
APP_PORT=8080

# -----------------------------------------------------------------------------
# Usuário/grupo do container (permite que arquivos gerados não fiquem como root)
# -----------------------------------------------------------------------------
WWWUSER=1000
WWWGROUP=1000

# -----------------------------------------------------------------------------
# Localização
# -----------------------------------------------------------------------------
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# -----------------------------------------------------------------------------
# Manutenção
# -----------------------------------------------------------------------------
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

# -----------------------------------------------------------------------------
# Segurança
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Banco de dados (MySQL)
# -----------------------------------------------------------------------------
# IMPORTANTE (Docker Compose): `DB_HOST` deve ser `mysql` (nome do serviço).
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=larasaas
DB_USERNAME=sail
DB_PASSWORD=password

# Portas expostas no host (evita conflito quando você roda dois MySQL: dev + testes).
FORWARD_DB_PORT=3306
FORWARD_DB_TEST_PORT=3310

# -----------------------------------------------------------------------------
# Sessão / Cache / Filas
# -----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

# -----------------------------------------------------------------------------
# Memcached / Redis (não usados por padrão neste compose; ajuste se adicionar serviços)
# -----------------------------------------------------------------------------
MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# E-mail (por padrão usa `log`; ajuste se usar SMTP/Mailpit)
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# AWS (opcional)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# -----------------------------------------------------------------------------
# Vite (frontend)
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# Configurações de usuários padrão
ADMIN_NAME="Administrador"
ADMIN_EMAIL="admin@larasaas.com"
ADMIN_PASSWORD="password"

# Configurações do SonarQube
SONAR_HOST_URL=http://localhost:9001
SONAR_LOGIN=SEU_TOKEN_AQUI
